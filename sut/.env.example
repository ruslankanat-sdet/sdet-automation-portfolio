# SUT (MedusaJS) environment — copy to .env and adjust as needed
DATABASE_URL=postgres://medusa:medusa@localhost:5432/medusa
POSTGRES_USER=medusa
POSTGRES_PASSWORD=medusa
POSTGRES_DB=medusa

# Backend
MEDUSA_BACKEND_PORT=9000
JWT_SECRET=supersecret-change-me
COOKIE_SECRET=supersecret-change-me

# Consumed by the suites (the seed step prints the real value into .sut-env)
# SUT_BASE_URL=http://localhost:9000
# UI_BASE_URL=http://localhost:8000
# MEDUSA_PUBLISHABLE_KEY=pk_...
